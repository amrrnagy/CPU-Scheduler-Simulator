<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="demo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Spacing="15" Margin="0,0,20,0">
            <TextBlock Text="CPU Scheduler" FontSize="24" FontWeight="Bold"/>

            <ComboBox x:Name="SchedulerCombo" Header="Select Scheduler" Width="280" SelectionChanged="SchedulerCombo_SelectionChanged">
                <ComboBoxItem Content="FCFS"/>
                <ComboBoxItem Content="SJF (Preemptive)"/>
                <ComboBoxItem Content="SJF (Non-Preemptive)"/>
                <ComboBoxItem Content="Priority (Preemptive)"/>
                <ComboBoxItem Content="Priority (Non-Preemptive)"/>
                <ComboBoxItem Content="Round Robin"/>
            </ComboBox>

            <Border Background="#1A1A1A" CornerRadius="8" Padding="15" Width="280" HorizontalAlignment="Left">
                <StackPanel Spacing="10">
                    <TextBlock Text="Add New Process" FontWeight="SemiBold"/>
                    <TextBox x:Name="BurstTimeInput" Header="Burst Time"/>
                    <TextBox x:Name="ArrivalTimeInput" Header="Arrival Time"/>
                    <TextBox x:Name="PriorityInput" Header="Priority (Lower = Higher)"/>
                    <Button Content="Add Process" HorizontalAlignment="Stretch" Click="AddProcess_Click"/>
                </StackPanel>
            </Border>

            <MenuFlyoutSeparator Margin="0,5,0,5" Width="280" HorizontalAlignment="Left"/>

            <Button Content="Run Live (1s = 1 unit)" Width="280" Style="{StaticResource AccentButtonStyle}" Click="RunLive_Click"/>
            <Button Content="Run Existing Only" Width="280" Click="RunStatic_Click"/>

            <Button Content="Reset Scheduler" Width="280" Background="#4A1A1A" Margin="0,15,0,0" Click="Reset_Click"/>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="30" Margin="0,0,0,20">
                <TextBlock x:Name="CurrentTimeText" Text="Time: 0s" FontSize="18" FontWeight="Bold" Foreground="LightSkyBlue"/>
                <TextBlock x:Name="AvgWaitText" Text="Avg Waiting Time: 0.0s" FontSize="18"/>
                <TextBlock x:Name="AvgTurnaroundText" Text="Avg Turnaround: 0.0s" FontSize="18"/>
            </StackPanel>

            <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,15">
                <Grid>
                    <TextBlock Text="Live Gantt Chart" Foreground="Gray" VerticalAlignment="Top"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,20,0,0">
                        <Canvas x:Name="GanttCanvas" Height="80" VerticalAlignment="Center"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10">
                <Grid>
                    <TextBlock Text="Remaining Burst Times" Foreground="Gray" VerticalAlignment="Top" Margin="0,0,0,10"/>

                    <ListView x:Name="ProcessTableListView" Margin="0,25,0,0" SelectionMode="None">
                        <ListView.Header>
                            <Grid Padding="10,8" Background="#2A2A2A" CornerRadius="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Process ID" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="Arrival" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="Burst" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3" Text="Priority" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="4" Text="Remaining Time" FontWeight="SemiBold"/>
                            </Grid>
                        </ListView.Header>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>